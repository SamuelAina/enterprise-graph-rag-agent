# API
APP_ENV=dev
API_KEY=change-me
ALLOW_NO_AUTH=false

# LLM (Azure OpenAI OR OpenAI-compatible)
LLM_PROVIDER=azure_openai
#LLM_PROVIDER=mock
LLM_API_KEY=?????
LLM_BASE_URL=????
LLM_DEPLOYMENT=gpt-4o-mini
LLM_API_VERSION=2024-02-15-preview

# If using OpenAI-compatible:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Retrieval tuning
TOP_K_DOCS=6
GRAPH_HOPS=2
MAX_CONTEXT_CHARS=8000

RERANK_ENABLED=true
PER_DOC_SNIPPET_CHARS=220
INCLUDE_SCORES_IN_CONTEXT=true

RERANK_ALPHA=0.65
RERANK_MMR_LAMBDA=1.0   
# set 0.8 to diversify